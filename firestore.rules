rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // WARNING: PUBLIC ACCESS ENABLED
    // ===============================================================
    // Anonymous Authentication is disabled in this Firebase project.
    // To allow the app to function with its custom PIN-based login,
    // read and write access are currently set to public.
    //
    // RECOMMENDATION: Enable "Anonymous" sign-in in the Firebase Console
    // (Authentication > Sign-in method) to allow securing these rules.
    // ===============================================================

    match /donations/{donationId} {
      allow read, write: if true;
    }

    match /expenses/{expenseId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /config/settings {
      allow read, write: if true;
    }

    match /auditLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /patients/{id} {
      allow read, write: if true;
    }

    match /doctors/{id} {
      allow read, write: if true;
    }

    match /machines/{id} {
      allow read, write: if true;
    }

    match /staff/{id} {
      allow read, write: if true;
    }

    match /ledger/{id} {
      allow read, write: if true;
    }

    match /paymentMethods/{id} {
      allow read, write: if true;
    }

    match /sessions/{id} {
      allow read, write: if true;
    }

    match /prescriptions/{id} {
      allow read, write: if true;
    }

    match /shifts/{id} {
      allow read, write: if true;
    }

    match /schedule/{id} {
      allow read, write: if true;
    }

    match /inventory/{id} {
      allow read, write: if true;
    }

    match /invoices/{id} {
      allow read, write: if true;
    }

    match /insuranceClaims/{id} {
      allow read, write: if true;
    }

    match /maintenanceLogs/{id} {
      allow read, write: if true;
    }
    
    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
